      "types": "./dist/topology.d.ts"
    },
    "./activations": {
      "import": "./dist/activations.js",
      "types": "./dist/activations.d.ts"
    },
    "./emit": {
      "import": "./dist/emit.js",
      "types": "./dist/emit.d.ts"
    },
    "./format": {
      "import": "./dist/format.js",
      "types": "./dist/format.d.ts"
    },
    "./runtime-format": {
      "import": "./dist/runtime-format.js",
      "types": "./dist/runtime-format.d.ts"
    },
    "./validate": {
      "import": "./dist/validate.js",
