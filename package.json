{
  "name": "@mcptoolshop/backprop-trace",
  "version": "0.2.0",
  "description": "Deterministic training-trace engine for explaining neural-network learning from receipts. v0.2 wires all eight reconciler rules against the Mazur 2-2-2 fixture, ships an Ajv-based schema validator, the canonical-bytes sha256 attestation seam, and four bp subcommands (reconcile / verify / generate / validate).",
  "type": "module",
  "license": "MIT",
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "homepage": "https://github.com/mcp-tool-shop-org/backprop-trace#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/backprop-trace.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/backprop-trace/issues"
  },
  "keywords": [
    "backpropagation",
    "neural-network",
    "deterministic",
    "trace-verifier",
    "reproducibility",
    "jsonl",
    "canonical-emission",
    "mazur",
    "sigmoid",
    "mse",
    "proof-of-learning",
    "reconciler"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./reconcile": {
      "import": "./dist/reconcile.js",
      "types": "./dist/reconcile.d.ts"
    },
    "./engine": {
      "import": "./dist/engine.js",
      "types": "./dist/engine.d.ts"
    },
    "./mazur": {
      "import": "./dist/mazur.js",
      "types": "./dist/mazur.d.ts"
    },
    "./emit": {
      "import": "./dist/emit.js",
      "types": "./dist/emit.d.ts"
    },
    "./format": {
      "import": "./dist/format.js",
      "types": "./dist/format.d.ts"
    },
    "./runtime-format": {
      "import": "./dist/runtime-format.js",
      "types": "./dist/runtime-format.d.ts"
    },
    "./validate": {
      "import": "./dist/validate.js",
      "types": "./dist/validate.d.ts"
    },
    "./parse": {
      "import": "./dist/parse.js",
      "types": "./dist/parse.d.ts"
    },
    "./hash": {
      "import": "./dist/hash.js",
      "types": "./dist/hash.d.ts"
    },
    "./schema-loader": {
      "import": "./dist/schema-loader.js",
      "types": "./dist/schema-loader.d.ts"
    },
    "./verify-engine": {
      "import": "./dist/verify-engine.js",
      "types": "./dist/verify-engine.d.ts"
    },
    "./extract": {
      "import": "./dist/extract.js",
      "types": "./dist/extract.d.ts"
    },
    "./schema": "./schemas/receipt.v0.1.0.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "bp": "./dist/bin/bp.js"
  },
  "files": [
    "dist/**",
    "schemas/**",
    "fixtures/**",
    "docs/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.28.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
