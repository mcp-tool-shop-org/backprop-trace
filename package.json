{
  "name": "@mcptoolshop/backprop-trace",
  "version": "0.8.0",
  "description": "Deterministic structural-trace verifier for neural-network training steps. Re-derives gradients, signals, and parameter updates from named factors via a 17-rule reconciler and emits canonical bytewise JSONL receipts. Ingests external PyTorch / JAX / TensorFlow training traces (single-step or multi-step v0.8+) via framework-trace sidecars with per-step engine-recompute differential + optional bundle-integrity binding. In the Csmith/CompCert lineage of 'the oracle must not consult the artifact it judges.' Mid-v0 (v0.8.x): CPU-only, SGD-only, hand-authored sidecars — see README 'What's not in this version (yet)' for v1.0 gaps.",
  "type": "module",
  "license": "MIT",
  "author": "mcp-tool-shop <64996768+mcp-tool-shop@users.noreply.github.com>",
  "homepage": "https://github.com/mcp-tool-shop-org/backprop-trace#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/backprop-trace.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/backprop-trace/issues"
  },
  "keywords": [
    "backpropagation",
    "neural-network",
    "deterministic",
    "trace-verifier",
    "reproducibility",
    "jsonl",
    "canonical-emission",
    "mazur",
    "sigmoid",
    "mse",
    "proof-of-learning",
    "reconciler",
    "general-topology",
    "multi-step",
    "topology-input",
    "per-neuron-bias",
    "authoring",
    "softmax",
    "cross-entropy",
    "log-sum-exp",
    "dual-form-verification",
    "pytorch-import",
    "jax-import",
    "tensorflow-import",
    "external-trace-ingestion",
    "observer-mode-receipts",
    "attestor",
    "differential-check",
    "in-toto",
    "slsa"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./reconcile": {
